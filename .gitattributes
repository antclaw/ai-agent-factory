# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Build outputs
dist/ text eol=lf
build/ text eol=lf

# Windows
*.bat text eol=crlf
*.cmd text eol=crlf

# macOS
.DS_Store binary

# Windows
Thumbs.db binary

# Logs
*.log text
npm-debug.log* text
yarn-debug.log* text
yarn-error.log* text
pnpm-debug.log* text
lerna-debug.log* text

# Dependencies
node_modules/ export-ignore
package-lock.json export-ignore
yarn.lock export-ignore
pnpm-lock.yaml export-ignore
bun.lockb export-ignore

# Git
.gitattributes export-ignore
.gitignore export-ignore
.github/ export-ignore
